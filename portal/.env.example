# Copy to .env and fill in. Never commit the real .env.
PAPERLESS_API_URL=http://localhost:8000
PAPERLESS_API_TOKEN=replace-with-paperless-api-token
ABSTRACT_FIELD_ID=1
TRADE_FIELD_ID=2
SOURCE_FIELD_ID=3

# Enrichment LLM (optional): anthropic | openai | none
LLM_PROVIDER=none
LLM_API_KEY=

# Backend CORS (frontend origin)
CORS_ORIGINS=http://localhost:5173

# Auth (shared passphrase). Generate a strong secret: openssl rand -hex 32
PORTAL_PASSWORD=set-a-password
PORTAL_SECRET=set-a-long-random-secret
