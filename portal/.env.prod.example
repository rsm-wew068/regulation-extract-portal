# Production secrets. Copy to .env.prod and fill in. NEVER commit .env.prod.

# Your domain (A record must point at the VPS). Caddy auto-provisions HTTPS.
DOMAIN=docs.yourcompany.com

# Strong random passwords/secrets (use: openssl rand -hex 32)
POSTGRES_PASSWORD=__change_me__
PAPERLESS_SECRET_KEY=__change_me__

# Created on the server after first boot (see DEPLOY.md). A read-only Paperless user.
PAPERLESS_API_TOKEN=__set_after_server_token_created__

# Custom-field IDs (verify on the server via: GET /api/custom_fields/ with the token)
ABSTRACT_FIELD_ID=1
TRADE_FIELD_ID=2
